{
    "name": "mdh-client",
    "version": "0.1.0",
    "private": true,
    "homepage": "/ephtportal",
    "dependencies": {
        "@emotion/react": "^11.9.3",
        "@emotion/styled": "^11.9.3",
        "@mui/icons-material": "^5.8.4",
        "@mui/lab": "^5.0.0-alpha.88",
        "@mui/material": "^5.8.6",
        "@mui/styles": "^5.8.6",
        "@mui/x-data-grid-pro": "^5.13.0",
        "@testing-library/jest-dom": "^5.16.5",
        "chart.js": "^3.8.0",
        "chartjs-chart-error-bars": "^3.8.0",
        "chartjs-plugin-annotation": "^1.4.0",
        "clsx": "^1.1.1",
        "css-what": "^5.0.1",
        "dompurify": "^2.2.8",
        "esri-leaflet": "^3.0.10",
        "esri-leaflet-renderers": "^2.1.2",
        "jszip": "^3.6.0",
        "leaflet": "^1.9.3",
        "leaflet-control-geocoder": "^2.4.0",
        "papaparse": "^5.3.0",
        "react": "^18.2.0",
        "react-chartjs-2": "^4.0.0",
        "react-dom": "^18.2.0",
        "react-error-boundary": "^3.1.3",
        "react-ga4": "^2.1.0",
        "react-leaflet": "^4.2.0",
        "react-router-dom": "^5.2.0"
    },
    "jest": {
        "transformIgnorePatterns": [
            "node_modules/(?!react-leaflet | @react-leaflet)/"
        ]
    },
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "build:staging": "env-cmd -f .env.staging npm run build",
        "build:development": "env-cmd -f .env.development npm run build",
        "format": "prettier --write \"{,!(node_modules)/**/}*.js\"",
        "lint": "eslint ./ --ignore-path .gitignore",
        "lint:fix": "npm run lint -- --fix",
        "test": "react-scripts test --runInBand --logHeapUsage",
        "eject": "react-scripts eject"
    },
    "eslintConfig": {
        "extends": "react-app"
    },
    "browserslist": [
        ">0.2%",
        "not dead",
        "not op_mini all"
    ],
    "devDependencies": {
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^13.4.0",
        "@testing-library/user-event": "^14.4.3",
        "env-cmd": "^10.1.0",
        "eslint": "^7.21.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-prettier": "6.10.1",
        "eslint-config-react-app": "^5.2.1",
        "eslint-plugin-import": "^2.22.1",
        "eslint-plugin-jsx-a11y": "6.2.3",
        "eslint-plugin-prettier": "3.1.3",
        "eslint-plugin-react": "7.19.0",
        "eslint-plugin-react-hooks": "2.5.1",
        "history": "^5.0.0",
        "husky": "^4.3.0",
        "jest-canvas-mock": "^2.3.0",
        "prettier": "^2.1.2",
        "react-scripts": "^4.0.3"
    },
    "husky": {
        "hooks": {
            "pre-commit": "npm run format && npm run lint:fix && git update-index --again"
        }
    }
}
